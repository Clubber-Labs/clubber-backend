{
  "uid": "connectai-database",
  "title": "ConnectAI Database & Pool",
  "tags": ["connectai", "database"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Conexões no Postgres (ativas vs. máximo)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(pg_stat_database_numbackends)",
          "legendFormat": "conexões ativas"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_settings_max_connections",
          "legendFormat": "max_connections"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Replication lag (s) — alerta de leituras velhas na réplica",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_replication_lag_seconds",
          "legendFormat": "lag"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Transações por segundo (commits + rollbacks)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_xact_commit[$__rate_interval]))",
          "legendFormat": "commits/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_xact_rollback[$__rate_interval]))",
          "legendFormat": "rollbacks/s"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cache hit ratio (shared buffers)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_blks_hit[$__rate_interval])) / (sum(rate(pg_stat_database_blks_hit[$__rate_interval])) + sum(rate(pg_stat_database_blks_read[$__rate_interval])))",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Pool de conexões do Prisma (por instância da API)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "prisma_pool_connections_busy",
          "legendFormat": "busy"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "prisma_pool_connections_idle",
          "legendFormat": "idle"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "prisma_pool_connections_open",
          "legendFormat": "open"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Queries do Prisma aguardando conexão (pressão no pool)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "prisma_client_queries_wait",
          "legendFormat": "aguardando"
        }
      ]
    }
  ]
}
