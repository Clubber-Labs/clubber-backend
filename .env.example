DATABASE_URL="postgresql://postgres:postgres@localhost:5432/conectai_dev"
JWT_SECRET="conectai_secret_dev"
PORT=3333
NODE_ENV=development

# Redis — opcional. Sem ele, o cache fica desabilitado e o rate limit opera em memória local.
REDIS_URL="redis://localhost:6379"

# Storage driver: "cloudinary" (default) ou "local"
STORAGE_DRIVER=cloudinary

# Public URL — usado pelo LocalStorageService para montar URLs servidas via /uploads
PUBLIC_URL=http://localhost:3333

# Diretório de uploads (usado quando STORAGE_DRIVER=local).
# Default: ./uploads relativo ao process.cwd().
UPLOADS_DIR=

# Cloudinary — configure DEV e PROD separadamente.
# O backend escolhe o par baseado em NODE_ENV (production = PROD, qualquer outro = DEV).
CLOUDINARY_CLOUD_NAME_DEV=
CLOUDINARY_API_KEY_DEV=
CLOUDINARY_API_SECRET_DEV=

CLOUDINARY_CLOUD_NAME_PROD=
CLOUDINARY_API_KEY_PROD=
CLOUDINARY_API_SECRET_PROD=

# Cloudinary — opcional. URL auth key (recurso pago) para URLs de mídia ASSINADAS
# com EXPIRAÇÃO (auth_token). Sem ela, as URLs são assinadas mas não expiram.
CLOUDINARY_AUTH_TOKEN_KEY=

# Chat — cota de armazenamento de mídia POR USUÁRIO, em bytes. Opcional.
# Default: 1 GB (1073741824). É um guarda-chuva anti-abuso/custo; um usuário
# normal não chega perto. Suba o valor se o app for mais pesado em vídeo.
CHAT_USER_STORAGE_QUOTA_BYTES=1073741824

# OAuth social — Google
# Client ID do OAuth Client criado no Google Cloud Console.
# Deve coincidir com o client_id usado pelo app mobile (audience do ID token).
GOOGLE_CLIENT_ID=

# OAuth social — Facebook
# App ID e App Secret do app criado em developers.facebook.com.
# O App Secret é usado para montar o app access token (debug_token).
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ──────────────────────────────────────────────────────────────────────────────
# Observabilidade — TODAS opcionais e OFF por padrão quando não configuradas.
# Stack local: observability/docker-compose.observability.yml (Prometheus, Tempo,
# Loki, Grafana). Métricas Prometheus ficam sempre expostas em GET /metrics.
# ──────────────────────────────────────────────────────────────────────────────

# Rastreio de erros (SDK Sentry). Sem DSN vira no-op (inclusive em testes).
# A stack local sobe um GlitchTip (compatível com Sentry, self-hosted) em :8000.
# Crie um projeto na UI (ou veja o README) e cole o DSN no formato:
#   SENTRY_DSN=http://<PUBLIC_KEY>@localhost:8000/<PROJECT_ID>
# Para usar o Sentry.io na nuvem, basta apontar para o DSN de lá (https://...).
SENTRY_DSN=

# OpenTelemetry tracing. Só ativa se OTEL_ENABLED=true E o endpoint OTLP definido.
# Aponta para o Tempo da stack local (OTLP HTTP em 4318).
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=connectai-backend

# Loki (logs centralizados, correlacionados ao trace pelo trace_id). Sem a URL,
# os logs ficam apenas no stdout. Aponta para o Loki da stack local.
LOKI_URL=http://localhost:3100

